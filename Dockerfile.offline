# 基础镜像
FROM alpine:latest

# 安装必要的软件
RUN apk add --no-cache nodejs npm

# 安装pnpm
RUN npm install -g pnpm

# 设置工作目录
WORKDIR /app

# 复制压缩文件
COPY ai-novel-writing-assistant.zip .

# 解压文件
RUN unzip ai-novel-writing-assistant.zip

# 进入解压后的目录
WORKDIR /app/dist-portable

# 安装依赖
RUN pnpm install

# 暴露端口
EXPOSE 3000 5173

# 启动应用
CMD ["pnpm", "dev"]